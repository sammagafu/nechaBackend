ADMIN_PASSWORD=admin12345

DEMO_GUEST_EMAIL=guest@necha.africa
DEMO_GUEST_PASSWORD=guest12345
DEMO_SHOPPER_EMAIL=shopper@necha.africa
DEMO_SHOPPER_PASSWORD=shop12345

KKOOAPP_BASE_URL=https://api.kkooapp.com/v1
