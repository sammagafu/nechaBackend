APP_ENV=development
SERVER_PORT=8080
CORS_ALLOWED_ORIGIN=https://necha.africa

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nechaafrica
DB_SSLMODE=disable

JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=168h

