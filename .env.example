KKOOAPP_ENDPOINT_HOTEL_RESERVATION=/reservations/hotel
KKOOAPP_ENDPOINT_TABLE_RESERVATION=/reservations/table
KKOOAPP_ENDPOINT_FOOD_ORDER=/orders/food
KKOOAPP_ENDPOINT_ORDER_STATUS=/orders/{id}/status

WEBHOOK_INBOUND_SECRET=

